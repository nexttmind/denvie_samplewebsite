# Required — set in Netlify: Site settings → Environment variables, then redeploy.
# Use either VITE_* or SUPABASE_* names (both work after build).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Aliases (optional if VITE_* vars above are set)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_PROJECT_ID=your-project-id

# Server-only — required for admin/server functions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
